          "docs": "List delivery blocks assigned to specific users."
        },
        {
          "info": {
            "name": "Get Delivery Blocks By Team",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://us2-admin-api.bringg.com/services/team_delivery_blocks"
          },
          "docs": "List delivery blocks for a team."
        }
      ]
